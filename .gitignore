# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Vite
.vite/
apps/web/dist/

# Generated from upstream FreeKill-release (run `pnpm --filter web sync-assets`).
# Upstream Lua source + game art (copyrighted, NOT redistributable) live here.
apps/web/public/fk/
# Any other synced upstream art / packages
**/image/generals/
**/image/card/*.png

# Upstream extension-pack mirror (replicates FreeKill-release/packages structure;
# ~1.5GB copyrighted Lua/art/audio, NOT redistributable). Ignore all pack CONTENT
# but KEEP the per-pack directory visible via a tracked .gitkeep + the README, so the
# pack list / layout survives in git and future packs can be ported without
# re-discovering the structure. See packages-upstream/README.md.
packages-upstream/*
!packages-upstream/README.md
!packages-upstream/*/
packages-upstream/*/*
!packages-upstream/*/.gitkeep

# Test / coverage
coverage/

# Editor / OS
.DS_Store
*.log
.idea/
.vscode/

# Env / secrets — never commit credentials, keys, or local server config
.env
.env.*
*.local
*.pem
*.key
*.crt
secrets.json
**/config.local.*
fk-*.log
