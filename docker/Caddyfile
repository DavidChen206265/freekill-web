# Caddyfile — public entry for FreeKill Web.
# Plain-HTTP deploy (no domain): Caddy listens on container :80, served on a host
# port via docker-compose. Browser hits http://<vps-ip>:<port>, and the app uses
# a same-origin ws://<vps-ip>:<port>/ws to reach the gateway. No TLS / Let's Encrypt
# (that path needs a real domain — switch the site address back to {$FK_DOMAIN} and
# republish 80/443 if you add one later).

:80 {
	encode zstd gzip

	# WebSocket gateway: browser connects to ws(s)://<host>/ws → gateway:9528.
	# Must be a `handle` so it's mutually exclusive with the SPA fallback below —
	# otherwise `try_files` rewrites /ws → /index.html before the proxy sees it and
	# the upgrade never reaches the gateway (HTTP 200 html instead of 101).
	handle /ws* {
		reverse_proxy gateway:9528
	}

	# Static game assets (art / audio / lua, synced into /srv/fk by sync-fk-assets).
	# These MUST 404 when missing — the client probes candidate URLs and relies on a
	# real 404 to fire <img>/<audio> onerror and fall through to the next candidate
	# (skin.ts cardPicCandidates, audio.ts playCandidates, EmotionSprite, ...). The
	# SPA fallback below would turn every miss into "200 index.html", which the client
	# can't decode as png/mp3 and never retries — so audio/animations silently break
	# on Linux (case-sensitive FS) even when they work on a Windows dev server, whose
	# vite returns a true 404. Keep this handle separate from the SPA handle: file_server
	# alone, no try_files, so a missing /fk/* path returns 404 (not index.html).
	#
	# Cache: revalidate, do NOT mark immutable. These filenames are NOT content-hashed
	# (jink.mp3 is always jink.mp3 even if its bytes change), so `immutable` would pin
	# stale bytes in every browser that ever fetched them — requiring a manual CF purge
	# AND a per-user cache clear on every asset update (and it's how a pre-fix bad
	# "200 index.html" got stuck across hard-refreshes). `no-cache` means "cache it but
	# always revalidate via ETag": file_server emits an ETag (size+mtime), the browser
	# sends If-None-Match, unchanged files get a cheap 304, changed files are fetched
	# immediately. So asset fixes propagate with no purge / no user action.
	handle /fk/* {
		root * /srv
		header Cache-Control "no-cache"
		file_server
	}

	# Everything else: the built React app (static). SPA fallback to index.html so
	# client-side routing works on refresh.
	handle {
		root * /srv

		# Long cache for hashed (content-addressed) JS/CSS bundles.
		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"

		# PWA control files MUST always revalidate so a new service worker / manifest
		# is picked up on the next visit (Workbox autoUpdate). Never cache them long.
		@swctl path /sw.js /registerSW.js /workbox-*.js /manifest.webmanifest
		header @swctl Cache-Control "no-cache"

		# PWA / browser icons at the site root (pwa-*.png, favicon.*, apple-touch-icon).
		# These are NOT content-hashed and were once served as "200 index.html" (when the
		# icon files were missing), which browsers heuristically cached — so a later valid
		# PNG is rejected as "not a valid image" until the stale html entry expires. Force
		# revalidation (ETag) so the corrected bytes are picked up on the next visit with
		# no manual cache clear, same rationale as the /fk no-cache fix.
		@icons path /pwa-*.png /favicon.png /favicon.ico /apple-touch-icon.png
		header @icons Cache-Control "no-cache"

		try_files {path} /index.html
		file_server
	}
}
